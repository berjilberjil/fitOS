{
  "name": "fitos-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "fitOS monorepo — SvelteKit web app + API (apps/web) and native SwiftUI iOS app (apps/ios).",
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "web": "npm --prefix apps/web run dev",
    "web:build": "npm --prefix apps/web run build",
    "web:check": "npm --prefix apps/web run check",
    "ios:gen": "cd apps/ios && xcodegen generate",
    "ios:open": "open apps/ios/fitOS.xcodeproj"
  }
}
