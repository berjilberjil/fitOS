{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "fitOS",
  "version": "0.1.0",
  "identifier": "com.berjil.fitos",
  "build": {
    "frontendDist": "../build",
    "devUrl": "https://fit.berjiljacob.com",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "fitOS",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "iOS": {
      "developmentTeam": "929G58HJFN"
    }
  }
}
